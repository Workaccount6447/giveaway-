# ─── Required ─────────────────────────────────────────────────
BOT_TOKEN=your_main_bot_token_here

# ─── Database ─────────────────────────────────────────────────
# MONGO=true  → MongoDB (recommended for Render/production)
# MONGO=false → SQLite local file (for local testing only)
MONGO=true
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/giveawaybot

# ─── Superadmin ───────────────────────────────────────────────
# Your Telegram user ID — get it from @userinfobot
SUPERADMIN_IDS=[123456789]

# ─── Web panel ────────────────────────────────────────────────
# Render sets PORT automatically — leave WEB_PORT unset on Render
# WEB_PORT=10000
WEB_DOMAIN=your-app.onrender.com

# ─── Local only (not needed on Render) ───────────────────────
# WEB_PORT=8080
